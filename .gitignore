# ── MATLAB ────────────────────────────────────────────────────────────────────
*.asv          # MATLAB auto-save backup files
*.m~           # temporary editor files
*.mex*         # compiled MEX files (platform-specific, don't commit)
*.slx          # Simulink files
*.slxc
octave-workspace

# MATLAB generated output files (these get recreated on every run)
GPA_Sem_*.txt
GPA_Sem_*.csv
class_results.csv
results.json

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/

# Virtual environments
env/
venv/
.venv/
ENV/

# ── Generated Output Folders ──────────────────────────────────────────────────
# PDF report cards are generated, not source code
report_cards/

# ── OS Files ──────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# ── Editors & IDEs ────────────────────────────────────────────────────────────
# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm etc.)
.idea/
*.iml

# Vim/Neovim
*.swp
*.swo
[._]*.s[a-v][a-z]
[._]*.sw[a-p]

# Emacs
\#*\#
.\#*

# ── Project-specific ignores ──────────────────────────────────────────────────
# Don't commit personal result files or test outputs
test_output/
scratch/
*.log
